PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/khmer_shop

# JWT
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_REFRESH_EXPIRES_IN=7d

# BCRYPT
BCRYPT_ROUNDS=12

# Frontend URL
CLIENT_URL=http://localhost:4200

# File Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

# KHQR / Bakong
BAKONG_API_URL=https://api-bakong.nbc.gov.kh
BAKONG_MERCHANT_ID=your_merchant_id
BAKONG_MERCHANT_NAME=KhmerShop
BAKONG_ACCOUNT_ID=your_bakong_account@nbcbank
BAKONG_CITY=Phnom Penh
KHQR_CURRENCY=USD
KHQR_QR_EXPIRY_MINUTES=15

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# Swagger
SWAGGER_HOST=localhost:5000
